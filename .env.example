# Kabbalah Environment Variables Example

# ============================================================================
# PROVIDER CONFIGURATION
# ============================================================================

# Provider Mode: unified, explicit, hierarchy, hybrid
KABBALAH_PROVIDER_MODE=unified

# Unified Mode: Single provider for all roles
KABBALAH_PROVIDER=openai
KABBALAH_MODEL=gpt-3.5-turbo

# Explicit Mode: Different providers per role
# KABBALAH_PROVIDER_MODE=explicit
# KABBALAH_INTAKE_PROVIDER=openai
# KABBALAH_INTAKE_MODEL=gpt-3.5-turbo
# KABBALAH_ROOT_PROVIDER=openai
# KABBALAH_ROOT_MODEL=gpt-3.5-turbo
# KABBALAH_DOMAIN_PROVIDER=google
# KABBALAH_DOMAIN_MODEL=gemini-pro
# KABBALAH_LEAF_BUILDER_PROVIDER=openai
# KABBALAH_LEAF_BUILDER_MODEL=gpt-3.5-turbo
# KABBALAH_LEAF_VERIFIER_PROVIDER=anthropic
# KABBALAH_LEAF_VERIFIER_MODEL=claude-3-sonnet
# KABBALAH_LEAF_AUDITOR_PROVIDER=anthropic
# KABBALAH_LEAF_AUDITOR_MODEL=claude-3-sonnet
# KABBALAH_SYNTHESIZER_PROVIDER=openai
# KABBALAH_SYNTHESIZER_MODEL=gpt-3.5-turbo

# ============================================================================
# LLM PROVIDER API KEYS
# ============================================================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Mistral
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here

# Together
TOGETHER_API_KEY=your_together_api_key_here

# Replicate
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ============================================================================
# RUNTIME CONFIGURATION
# ============================================================================

# Runtime Mode: BOOTSTRAP, DAY1, DAY2
V5_RUNTIME_MODE=BOOTSTRAP

# ============================================================================
# MEMORY CONFIGURATION
# ============================================================================

# Memory Backend: cognee or jsonl
KABBALAH_MEMORY_BACKEND=cognee

# Cognee Configuration
COGNEE_ENABLED=true
COGNEE_HOST=localhost
COGNEE_PORT=5432

# JSONL Fallback
KABBALAH_JSONL_ENABLED=true
KABBALAH_JSONL_PATH=./data/memory.jsonl
KABBALAH_JSONL_MAX_SIZE_MB=1000

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Observability
KABBALAH_OBSERVABILITY_ENABLED=true

# Tracing
KABBALAH_TRACING_ENABLED=true
KABBALAH_TRACING_EXPORTER=jaeger
JAEGER_HOST=localhost
JAEGER_PORT=6831

# Metrics
KABBALAH_METRICS_ENABLED=true
KABBALAH_METRICS_EXPORTER=prometheus
PROMETHEUS_PORT=8000

# Logging
KABBALAH_LOG_LEVEL=INFO
KABBALAH_LOG_FORMAT=json
KABBALAH_LOG_FILE=./logs/kabbalah.log

# ============================================================================
# TOOL EXECUTION CONFIGURATION
# ============================================================================

# Tool Execution
KABBALAH_TOOLS_ENABLED=true

# Sandboxing
KABBALAH_SANDBOX_ENABLED=true
KABBALAH_SANDBOX_CPU_LIMIT=2
KABBALAH_SANDBOX_MEMORY_LIMIT_MB=512
KABBALAH_SANDBOX_DISK_LIMIT_MB=1000
KABBALAH_SANDBOX_TIMEOUT_SECONDS=30

# ============================================================================
# PERFORMANCE CONFIGURATION
# ============================================================================

# Parallel Execution
KABBALAH_MAX_PARALLEL_DOMAINS=10
KABBALAH_MAX_PARALLEL_LEAF_NODES=100

# Timeouts
KABBALAH_DECOMPOSITION_TIMEOUT_SECONDS=30
KABBALAH_SYNTHESIS_TIMEOUT_SECONDS=60
KABBALAH_OPERATION_TIMEOUT_SECONDS=300

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Encryption
KABBALAH_ENCRYPTION_ENABLED=true
KABBALAH_ENCRYPTION_ALGORITHM=AES-256

# Audit Logging
KABBALAH_AUDIT_LOGGING_ENABLED=true
KABBALAH_AUDIT_LOGGING_IMMUTABLE=true
KABBALAH_AUDIT_LOG_FILE=./logs/audit.log

# Access Control
KABBALAH_ACCESS_CONTROL_ENABLED=true
KABBALAH_ACCESS_CONTROL_STRICT_MODE=true

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================

# Debug Mode
KABBALAH_DEBUG=false

# Verbose Logging
KABBALAH_VERBOSE=false

# Mock Providers (for testing)
KABBALAH_MOCK_PROVIDERS=false

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application Name
APP_NAME=Kabbalah

# Application Version
APP_VERSION=0.1.0

# Environment
ENVIRONMENT=development
