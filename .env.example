# Mistral
MISTRAL_API_KEY=YOUR_KEY_HERE

# Anthropic (for later)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
